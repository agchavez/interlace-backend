# Base de datos PostgreSQL
DB_NAME=tracker_db
DB_USER=postgres
DB_PASSWORD=tu_password_seguro
DB_HOST=host.docker.internal  # Para Docker en producción
DB_PORT=5432

# Django
DEBUG=False
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-segura-y-larga
FRONTEND_URL=https://tu-dominio.com

# Email (opcional)
EMAIL_USE_TLS=True
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password-de-aplicacion
EMAIL_PORT=587

# Redis para Celery y Channels (WebSockets)
REDIS_HOST=redis  # Nombre del servicio en docker-compose
REDIS_PORT=6379
CELERY_BROKER_REDIS_URL=redis://redis:6379/0

